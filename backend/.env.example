# Copy this file to .env and fill in your values
# DO NOT commit .env to git

SECRET_KEY="your-flask-secret-key-here"
DATABASE_URL="sqlite:///rams_v2.db"   # Dev: SQLite | Prod: PostgreSQL URL from Render
JWT_SECRET="your-jwt-secret-here"

# CORS - set this to your Vercel frontend URL in production
FRONTEND_URL="https://your-app.vercel.app"

# Required for Celery background tasks (Publication Sync)
CELERY_BROKER_URL="redis://localhost:6379/0"   # Prod: Redis URL from Render
